# naia-os — example environment
#
# Copy to `.env` (gitignored) and fill in your own values. Every variable here
# is OPTIONAL: the app runs without any of them. They exist to point the shell
# at your own workspace, agent, model providers, and test backends.
#
# Nothing in this file is a real credential — all values are placeholders.

# ── Workspace / agent paths ──────────────────────────────────────────────────
# Default workspace root the shell opens (overridden in-app via Settings).
# Falls back to $HOME/dev (Unix) or %USERPROFILE%\dev (Windows) when unset.
NAIA_WORKSPACE_ROOT=/path/to/workspace

# Path to your naia-adk workspace checkout (settings/config live here).
NAIA_ADK_PATH=/path/to/naia-adk

# Path to the naia-agent runtime entry / script (for the brain process).
NAIA_AGENT_PATH=/path/to/naia-agent
NAIA_AGENT_SCRIPT=/path/to/naia-agent/scripts/agent-stdio-entry.mjs
# Used only by the optional Rust live gRPC diagnostic test.
NAIA_AGENT_ENTRY=/path/to/naia-agent/scripts/agent-stdio-entry.mjs

# ── Model provider API keys (only what you actually use) ─────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Naia Gateway key (gw- prefix) for the hosted gateway path.
NAIA_API_KEY=

# ── E2E / test harness (optional) ────────────────────────────────────────────
# Route e2e specs at a dev gateway instead of prod.
VITE_NAIA_USE_DEV_GATEWAY=0
VITE_NAIA_DEV_GATEWAY_URL=https://your-dev-gateway.example.com
# Direct-provider key for semantic-judge e2e specs.
CAFE_E2E_API_KEY=
CAFE_E2E_JUDGE_MODEL=
# Local voice/omni backend host for voice e2e specs.
VLLM_OMNI_HOST=your-host:8892
