# Naia Shell — E2E-only environment
# Copy to .env.e2e (gitignored). Loaded by wdio.conf.ts ONLY — never
# touched by `pnpm run tauri:dev`.
#
# Why a separate file?
# `.env` is auto-loaded by Vite at build time, so anything VITE_* there
# affects BOTH e2e and normal dev runs. Putting the dev-gateway URL in
# .env would force tauri:dev to use the dev gateway and 401 any prod
# OAuth-logged-in user. Keep e2e-only knobs here, isolated.
#
# Resolution order (wdio.conf.ts):
#   .env.e2e  >  .env  (first-match-wins per key)

# Dev gateway for e2e specs (Cloud Run). Required so spec 04-skill-time
# can hit a working backend without the prod 500 (#331).
# The USE flag is what flips config.ts:561 — both must be set to actually
# route to dev.
VITE_NAIA_USE_DEV_GATEWAY=1
VITE_NAIA_DEV_GATEWAY_URL=https://your-dev-gateway.example.com

# Dev gateway API key (issued at https://naia.nextain.io/keys via local
# Next.js dev server pointed at dev gateway). gw- prefix, 48 chars.
NAIA_API_KEY=

# E2E test runner overrides. CAFE_E2E_API_KEY takes priority over
# GEMINI_API_KEY for direct-Gemini specs (Suites 3 & 4 semantic judge).
CAFE_E2E_API_KEY=

# Judge model used by semantic assertions. Defaults to gemini-2.5-flash.
CAFE_E2E_JUDGE_MODEL=

# Mock GitHub clone + agent-kill on delete (auto-set by wdio.conf.ts).
# Set here too if you want to spin up tauri:dev with the mock for manual
# verification of the ADK setup screen.
# NAIA_E2E_MOCK_CLONE=1
