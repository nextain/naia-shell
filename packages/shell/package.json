{
  "name": "naia-shell",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node ../scripts/dev-setup.mjs && node ../scripts/tauri-with-mode.mjs dev",
    "tauri:prod": "node ../scripts/dev-setup.mjs && node ../scripts/tauri-with-mode.mjs prod",
    "tauri:dev:clean": "node ../scripts/dev-setup.mjs --clean && node ../scripts/tauri-with-mode.mjs dev",
    "tauri:build:local": "pnpm run tauri build --config src-tauri/tauri.conf.local.json",
    "tauri:build:windows:local": "cd ../agent && pnpm install --frozen-lockfile && pnpm run build && cd ../shell && pnpm build && python3 ../scripts/prune-nsis.py && pnpm run tauri build --config src-tauri/tauri.conf.windows.json --config src-tauri/tauri.conf.windows-local.json",
    "check": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:tauri": "wdio run e2e-tauri/wdio.conf.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.10.8",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.36.4",
    "@nextain/naia-os-core": "workspace:*",
    "@pixiv/three-vrm": "^3.4.5",
    "@pixiv/three-vrm-animation": "^3.4.5",
    "@pixiv/three-vrm-core": "^3.4.5",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@types/dompurify": "^3.2.0",
    "@types/papaparse": "^5.5.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "dompurify": "^3.3.3",
    "mermaid": "^11.13.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "5.4.296",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "remark-gfm": "^4.0.1",
    "tauri-plugin-stt-api": "^0.1.1",
    "three": "^0.172.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.50.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.172.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.0.18",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "wdio-video-reporter": "^6.2.0",
    "ws": "^8.19.0"
  }
}