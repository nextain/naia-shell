	"common": {
		"$comment": "3 OS 공통 그룹 — agent 스테이징 산출물 매핑(R4: gitignored 산출물이라 base 등재 금지) + updater 아티팩트 비활성(서명키 부재 시 빌드 실패 차단, 3 OS 전부).",
		"createUpdaterArtifacts": false,
		"resources": {
			"agent/dist": "agent/dist",
			"agent/scripts": "agent/scripts",
			"agent/package.json": "agent/package.json",
			"agent/node_modules": "agent/node_modules",
			"bgm-sidecar/dist": "bgm-sidecar/dist",
			"bgm-sidecar/package.json": "bgm-sidecar/package.json",
			"bgm-sidecar/node_modules": "bgm-sidecar/node_modules"
		},
		"staging": {
			"agent": "required",
			"bgmSidecar": "required",
			"cascadeLoader": "optional"
		},
		"cascadeLoaderResources": {
			"cascade-loader/loader": "cascade-loader/loader"
		}
	},
	"os": {
		"win32": {
			"targets": ["nsis", "msi"],
			"bundleArchs": ["x64"],
			"$bundleArchComment": "Vosk 0.3.45 산출물이 win64 + /MACHINE:X64 고정 — arm64 전체 번들은 명확 차단. Node arm64 아카이브 메타데이터는 유지.",
			"nodeBinary": "node.exe",
			"wrappedStaticExecutables": [],
			"vosk": {
				"$comment": "dll 4종 전부 — libvosk 가 MinGW 트리오에 load-time 의존, 누락 = 기동 실패. 생성 주체 = tauri-plugin-stt build.rs(setup_vosk), stage-runtime 은 프로비저닝·검사하지 않음(순서 보증 = 플러그인 Cargo.toml links 키).",
				"archive": {
					"file": "vosk-win64-0.3.45.zip",
					"sha256": "f1dcc9cca460630f81ea8f71794f69c80bed6556d2a4e6237b5785e1d2dff34b"
				},
				"files": [
					"libvosk.dll",
					"libgcc_s_seh-1.dll",
					"libstdc++-6.dll",
					"libwinpthread-1.dll"
				]
			},
			"msvcRedist": {
				"$comment": "원본 = env VCToolsRedistDir 우선, 없으면 vswhere 로 VS 설치 경로 조회 후 VC/Redist/MSVC/<ver>/<arch>/Microsoft.VC*.CRT 규약 탐색. 미발견 = 탐색 경로 나열 후 중단(조용한 생략 금지).",
				"files": ["msvcp140.dll", "vcruntime140.dll", "vcruntime140_1.dll"]
			},
			"installer": {
				"publisher": "Nextain Inc.",
				"windows": {
					"certificateThumbprint": null,
					"digestAlgorithm": "sha256",
					"webviewInstallMode": {
						"type": "offlineInstaller"
					},
					"nsis": {
						"installMode": "currentUser",
						"displayLanguageSelector": false,
						"languages": ["Korean", "English"]
					}
				}
			},
			"artifacts": [
				{ "glob": "nsis/*-setup.exe", "minBytes": 237516523 },
				{ "glob": "msi/*.msi", "minBytes": 297402764 }
			],
			"steamDepot": {
				"path": "steam/windows",
				"entrypoint": "naia-shell.exe",
				"requiredFiles": [
					"naia-shell.exe",
					"node.exe",
					"agent/package.json",
					"bgm-sidecar/package.json",
					"bgm-sidecar/dist/bgm-server-bin.js",
					"bgm-sidecar/dist/youtube-server.js",
					"bgm-sidecar/node_modules/youtubei.js/package.json"
				],
				"excludedFiles": ["uninstall.exe"],
				"manifest": "steam-files.sha256"
			}
		},
		"linux": {
			"targets": ["appimage", "deb", "rpm"],
			"bundleArchs": ["x64"],
			"$bundleArchComment": "Vosk 0.3.45 산출물이 linux-x86_64 고정 — arm64 전체 번들은 명확 차단. Node arm64 아카이브 메타데이터는 유지.",
