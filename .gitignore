# Dependencies
node_modules/
.pnp
.pnp.js

# Build artifacts
dist/
build/
*.tsbuildinfo
*.js.map

# Environment / secrets — NEVER commit
*.env
!*.env.example
*.json.local
.naia-agent.json
naia-agent.env

# Archive (local only)
*-old/
*-archive/

# OS
.DS_Store
Thumbs.db
ehthumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# AI 작업 임시물 + 주기 검증 러너 산출물 (로그/상태/PID — 추적 제외)
.agents/work/

# Editor
.vscode/
.idea/
*.swp
*.swo

# T3 보안 — 키/시크릿/개인정보 (절대 추적 금지, README 마커만)
data-private/
!data-private/README.md

# 보류 격리(Quarantine) — 방치 의심 자산 백업. 실물은 추적 제외, MANIFEST/README 만 추적
# (컨텍스트가 "백업 자산이 있었다"를 알도록). scripts/quarantine.mjs 가 관리.
quarantine/*
!quarantine/MANIFEST.json
!quarantine/README.md

# builds/ 생성물 (f0-graft-smoke.sh 가 만드는 붙여넣기 스니펫)
scripts/builds/f0-graft-snippet.js
scripts/builds/uc1-graft-snippet.js
packages/*/node_modules
packages/*/dist
packages/shell/src-tauri/target
packages/shell/src-tauri/gen
# 번들 바이너리 리소스(vosk dll, node.exe 등 ~140MB) — 빌드 시 복사, 추적 제외
packages/shell/src-tauri/resources/
