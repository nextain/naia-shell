# Naia Shell — Environment Variables
# Copy this file to .env and fill in your values.
#
# Variable naming history note: CAFE_* names are historical (originated in the
# cafelua project lineage) and are pending rename to NAIA_*. See open issue
# for tracking.

# ─── LLM Provider API Keys (direct) ──────────────────────────────────────────
# At least one of these is required for the shell to make LLM calls without
# going through the naia lab proxy. Used by e2e tests when NAIA_API_KEY is
# not configured or for local development against Gemini/OpenAI/etc directly.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
ZHIPU_API_KEY=

# ─── naia Lab Proxy (cloud LLM via naia.nextain.io) ──────────────────────────
# Key issued at https://naia.nextain.io/dashboard/api-keys
# Required for production "lab" flow (provider=nextain in shell config).
NAIA_API_KEY=

# ─── Gateway URLs (Cloud Run) ────────────────────────────────────────────────
# Shell uses VITE_* (build-time, Vite-injected). Agent uses NAIA_GATEWAY_URL
# (runtime, Node process). Keep both in sync to avoid split-brain where the
# shell points at one gateway and the agent calls another.
#
# Leave empty to use the production default
# (https://naia-gateway-181404717065.asia-northeast3.run.app).
VITE_NAIA_GATEWAY_URL=
VITE_NAIA_DEV_GATEWAY_URL=
NAIA_GATEWAY_URL=

# ─── Local Gateway (agent ↔ gateway WebSocket auth) ──────────────────────────
# Token must match gateway.auth.token in the local gateway config.
# Default suitable for dev: "naia-dev-token".
CAFE_GATEWAY_TOKEN=naia-dev-token

# ─── E2E Test Configuration ──────────────────────────────────────────────────
# CAFE_E2E_API_KEY takes priority over GEMINI_API_KEY in e2e specs (helpers
# and most specs read `process.env.CAFE_E2E_API_KEY ?? process.env.GEMINI_API_KEY`).
# Use this when you want a different key in e2e than in dev/manual runs.
CAFE_E2E_API_KEY=

# Judge model used by e2e semantic assertions (helpers/semantic.ts).
# Defaults to gemini-2.5-flash if unset.
CAFE_E2E_JUDGE_MODEL=

# Enables verbose Tauri/agent debug logging during e2e runs.
# Set to "1" to enable; auto-set by wdio.conf.ts.
# CAFE_DEBUG_E2E=1

# E2E mock: skip GitHub clone + agent-kill-before-delete for ADK setup
# scenarios. Auto-set by wdio.conf.ts; do not set manually for dev runs.
# NAIA_E2E_MOCK_CLONE=1
