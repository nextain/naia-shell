exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -NoProfile -Command "Get-Content -LiteralPath 'D:\\alpha-adk\\projects\\naia-os\\.agents\\context\\agents-rules.json'" in D:\alpha-adk\projects\naia-os
