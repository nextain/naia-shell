{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "node .claude/hooks/release-guard.js"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node .claude/hooks/process-guard.js"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "node .claude/hooks/sync-entry-points.js"
					},
					{
						"type": "command",
						"command": "node .claude/hooks/cascade-check.js"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "node .claude/hooks/commit-guard.js"
					},
					{
						"type": "command",
						"command": "node .claude/hooks/dll-bundle-check.js"
					}
				]
			}
		]
	}
}
